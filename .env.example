# Multi-AI providers
# GPT-5.5 (OpenAI format) and Claude Opus 4.8 (Anthropic format) share one gateway key.
JDCLOUD_API_KEY=
JDCLOUD_BASE_URL=https://modelservice.jdcloud.com/v1
JDCLOUD_ANTHROPIC_URL=https://modelservice.jdcloud.com/anthropic
GPT_MODEL=GPT-5.5
OPUS_MODEL=Claude-Opus-4.8
QWEN_MODEL=Qwen3-235B-A22B
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Optional: enables automatic XRP risk updates on Coston2.
# Use a dedicated testnet wallet only. Never use a mainnet private key.
PRIVATE_KEY=

# Optional: API and dashboard port.
PORT=8078
